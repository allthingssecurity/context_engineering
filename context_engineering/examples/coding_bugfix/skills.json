[
  {
    "id": "coding_bugfix_v1",
    "description": "Bug-fix context: boost stack-trace files, keep code/tests/logs only.",
    "task_types": ["coding_bugfix"],
    "rule_scopes": ["coding"],
    "resource_types": ["code_file", "test_file", "log"],
    "operators": [
      "rule_selector",
      "lexical_retrieval",
