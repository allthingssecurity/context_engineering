      "type_filter",
      "relevance_rank",
      "dedupe",
      "budget_compressor",
      "context_formatter"
    ],
    "context_template": "code",
    "default_budget_tokens": 1200,
    "evaluators": [
      "budget_evaluator",
      "required_rule_evaluator",
      "gold_resource_recall_evaluator",
      "coding_context_evaluator"
    ],
    "metadata": {"top_k": 4, "default": true}
  }
]
